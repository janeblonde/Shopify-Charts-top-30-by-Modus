<style>
  .sd-chart {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px 80px;
    font-family: inherit;
  }
  .sd-chart__header {
    text-align: center;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 2px solid currentColor;
  }
  .sd-chart__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 8px;
  }
  .sd-chart__title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 16px;
  }
  .sd-chart__date {
    font-size: 13px;
    opacity: 0.6;
    letter-spacing: 0.05em;
  }
  .sd-chart__loading {
    text-align: center;
    padding: 80px 20px;
    opacity: 0.4;
    font-size: 14px;
  }
  .sd-chart__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sd-chart__entry {
    display: grid;
    grid-template-columns: 56px 52px 72px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 14px 8px;
    border-bottom: 1px solid rgba(128,128,128,0.15);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    border-radius: 6px;
  }
  .sd-chart__entry:hover {
    background: rgba(128,128,128,0.06);
  }
  .sd-chart__pos {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    text-align: right;
    opacity: 0.15;
    min-width: 40px;
    transition: opacity 0.15s;
  }
  .sd-chart__entry:hover .sd-chart__pos {
    opacity: 1;
  }
  .sd-chart__pos--top3 {
    opacity: 1 !important;
  }
  .sd-chart__movement {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
  }
  .sd-chart__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 7px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .sd-chart__badge--new  { background: #000; color: #fff; }
  .sd-chart__badge--up   { background: rgba(34,197,94,0.12); color: #16a34a; }
  .sd-chart__badge--down { background: rgba(239,68,68,0.1);  color: #dc2626; }
  .sd-chart__badge--same { background: rgba(128,128,128,0.1); color: rgba(128,128,128,0.8); font-size: 14px; }
  .sd-chart__image {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: rgba(128,128,128,0.1);
  }
  .sd-chart__image--placeholder {
    width: 72px;
    height: 72px;
    border-radius: 4px;
    background: rgba(128,128,128,0.1);
  }
  .sd-chart__info { min-width: 0; }
  .sd-chart__product-title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sd-chart__meta {
    font-size: 12px;
    opacity: 0.5;
    margin: 0;
  }
  .sd-chart__units {
    font-size: 20px;
    font-weight: 700;
    text-align: right;
    white-space: nowrap;
    opacity: 0.35;
  }
  .sd-chart__units span {
    display: block;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  @media (max-width: 600px) {
    .sd-chart__entry { grid-template-columns: 40px 44px 56px 1fr; }
    .sd-chart__units { display: none; }
    .sd-chart__pos   { font-size: 22px; }
    .sd-chart__image,
    .sd-chart__image--placeholder { width: 56px; height: 56px; }
    .sd-chart__product-title { font-size: 13px; }
  }
</style>

<div class="sd-chart section-spacing{% if section.settings.disable_top_spacing %} section-spacing--disable-top{% endif %}{% if section.settings.disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}">
  <div class="sd-chart__header">
    <p class="sd-chart__eyebrow">Spindizzy Records</p>
    <h1 class="sd-chart__title">The Weekly Top 30</h1>
    <p class="sd-chart__date" id="sd-chart-date">Loading chart&hellip;</p>
  </div>
  <div id="sd-chart-body">
    <p class="sd-chart__loading">Loading chart data&hellip;</p>
  </div>
</div>

<script>
(function () {
  var CHART_URL = 'https://raw.githubusercontent.com/janeblonde/Shopify-Charts-top-30-by-Modus/main/chart-data.json';
  var SHOW_UNITS = {{ section.settings.show_units | json }};

  function formatDate(iso) {
    var d = new Date(iso);
    return d.toLocaleDateString('en-IE', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
  }

  function badge(entry) {
    var prev = entry.previous_position;
    var cur  = entry.position;
    if (prev === null || prev === undefined) {
      return '<span class="sd-chart__badge sd-chart__badge--new">NEW</span>';
    } else if (prev > cur) {
      return '<span class="sd-chart__badge sd-chart__badge--up">&#9650; ' + (prev - cur) + '</span>';
    } else if (prev < cur) {
      return '<span class="sd-chart__badge sd-chart__badge--down">&#9660; ' + (cur - prev) + '</span>';
    } else {
      return '<span class="sd-chart__badge sd-chart__badge--same">&mdash;</span>';
    }
  }

  function imgSrc(url) {
    if (!url) return '';
    return url.replace(/(\.[a-z]+)(\?|$)/, '_160x160_crop_center$1$2');
  }

  function render(data) {
    // Update date header
    var dateEl = document.getElementById('sd-chart-date');
    if (dateEl && data.week_end) {
      dateEl.innerHTML = 'Week ending <strong>' + formatDate(data.week_end) + '</strong>';
    }

    var entries = data.chart || [];
    if (entries.length === 0) {
      document.getElementById('sd-chart-body').innerHTML = '<p class="sd-chart__loading">No chart data available yet.</p>';
      return;
    }

    var html = '<ol class="sd-chart__list">';
    entries.forEach(function (entry) {
      var isTop3 = entry.position <= 3;
      var prev   = entry.previous_position;
      var metaText = (prev === null || prev === undefined) ? 'New entry' : 'Last week: #' + prev;
      var imgHtml = entry.image
        ? '<img class="sd-chart__image" src="' + imgSrc(entry.image) + '" alt="" width="72" height="72" loading="lazy">'
        : '<div class="sd-chart__image--placeholder"></div>';
      var unitsHtml = SHOW_UNITS
        ? '<div class="sd-chart__units">' + entry.units + '<span>sold</span></div>'
        : '';

      html += '<li>';
      html += '<a href="/products/' + entry.handle + '" class="sd-chart__entry">';
      html += '<div class="sd-chart__pos' + (isTop3 ? ' sd-chart__pos--top3' : '') + '">' + entry.position + '</div>';
      html += '<div class="sd-chart__movement">' + badge(entry) + '</div>';
      html += imgHtml;
      html += '<div class="sd-chart__info">';
      html += '<p class="sd-chart__product-title">' + entry.title.replace(/</g, '&lt;') + '</p>';
      html += '<p class="sd-chart__meta">' + metaText + '</p>';
      html += '</div>';
      html += unitsHtml;
      html += '</a></li>';
    });
    html += '</ol>';

    document.getElementById('sd-chart-body').innerHTML = html;
  }

  fetch(CHART_URL + '?t=' + Date.now())
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(render)
    .catch(function (err) {
      document.getElementById('sd-chart-body').innerHTML = '<p class="sd-chart__loading">Chart data not yet available -- check back after Wednesday midnight.</p>';
      document.getElementById('sd-chart-date').textContent = '';
      console.warn('Chart load error:', err);
    });
})();
</script>

{% schema %}
{
  "name": "Weekly Chart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_units",
      "label": "Show units sold",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_top_spacing",
      "default": false,
      "label": "Remove top spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_bottom_spacing",
      "default": false,
      "label": "Remove bottom spacing"
    }
  ],
  "presets": [
    {
      "name": "Weekly Chart"
    }
  ],
  "enabled_on": {
    "templates": ["page"]
  }
}
{% endschema %}